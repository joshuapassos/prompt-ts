{
  "name": "@joshuapassos/prompt-ts",
  "version": "1.2.0",
  "description": "Type-safe prompt templating engine with Zod schema support",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "knip": "knip"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joshuapassos/prompt-ts.git"
  },
  "license": "MIT",
  "author": "Joshua Passos",
  "packageManager": "pnpm@10.11.0",
  "dependencies": {
    "zod": "^3.25.32"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "knip": "^6.0.6",
    "typescript": "~6.0.2",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist/**"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
